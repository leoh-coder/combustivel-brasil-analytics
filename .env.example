# Variáveis de ambiente do projeto Combustível Brasil Analytics
# Copie este arquivo para .env e preencha os valores
# O .env nunca deve ser commitado no git

# AWS S3 — necessário apenas para upload/download dos dados na nuvem
AWS_ACCESS_KEY_ID=sua_access_key_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_aqui
AWS_REGION=sa-east-1
S3_BUCKET_NAME=combustivel-brasil-analytics
